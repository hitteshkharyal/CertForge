# Frontend Environment Variables

# The URL of your backend API. 
# During local development, you can leave this empty or point to your local server.
# In production (Netlify), set this in the Netlify dashboard to your Render backend URL.
# Example for production: VITE_API_URL=https://certificate-backend.onrender.com/api

VITE_API_URL=http://localhost:5000/api
